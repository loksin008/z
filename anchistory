#!/bin/bash

# Ancient Indian History Bash Script
# This script provides an overview of significant periods, events, and personalities of ancient Indian history.

echo "======================================="
echo "      Indian Ancient History Guide"
echo "======================================="

# Function to display the main menu
main_menu() {
    echo "Choose a historical period to explore:"
    echo "1. Indus Valley Civilization (3300-1300 BCE)"
    echo "2. Vedic Period (1500-500 BCE)"
    echo "3. Mahajanapadas (600-300 BCE)"
    echo "4. Maurya Empire (322-185 BCE)"
    echo "5. Gupta Empire (320-550 CE)"
    echo "6. Sangam Period (300 BCE - 300 CE)"
    echo "7. Exit"
    echo
    read -p "Enter your choice [1-7]: " choice
}

# Function to display details about each period
display_period() {
    case $1 in
        1)
            echo "---------------------------------------"
            echo "Indus Valley Civilization (3300-1300 BCE)"
            echo "---------------------------------------"
            echo "The Indus Valley Civilization, one of the world's oldest civilizations, was known for its advanced urban planning,"
            echo "architecture, and social organization. Major sites include Mohenjo-daro, Harappa, and Dholavira."
            echo
            ;;
        2)
            echo "---------------------------------------"
            echo "Vedic Period (1500-500 BCE)"
            echo "---------------------------------------"
            echo "The Vedic Period is named after the Vedas, the oldest sacred texts of Hinduism. This era saw the formation of"
            echo "social, cultural, and religious foundations in ancient India. Key texts: Rigveda, Samaveda, Yajurveda, Atharvaveda."
            echo
            ;;
        3)
            echo "---------------------------------------"
            echo "Mahajanapadas (600-300 BCE)"
            echo "---------------------------------------"
            echo "The Mahajanapadas were sixteen powerful kingdoms or oligarchic republics. Notable Mahajanapadas include Magadha, Kosala,"
            echo "and Vatsa. This period set the stage for the emergence of the first major empires."
            echo
            ;;
        4)
            echo "---------------------------------------"
            echo "Maurya Empire (322-185 BCE)"
            echo "---------------------------------------"
            echo "Founded by Chandragupta Maurya, this was one of the largest empires in ancient India. Emperor Ashoka, a prominent"
            echo "ruler, promoted Buddhism after the Kalinga War. The Arthashastra and Ashokan Edicts are significant texts from this era."
            echo
            ;;
        5)
            echo "---------------------------------------"
            echo "Gupta Empire (320-550 CE)"
            echo "---------------------------------------"
            echo "The Gupta Empire is often referred to as the 'Golden Age' of India, known for advancements in science, mathematics,"
            echo "astronomy, literature, and art. Key figures include Samudragupta and Chandragupta II."
            echo
            ;;
        6)
            echo "---------------------------------------"
            echo "Sangam Period (300 BCE - 300 CE)"
            echo "---------------------------------------"
            echo "A period of significant Tamil literature and poetry, the Sangam Period was marked by extensive trade and commerce"
            echo "with Rome and Southeast Asia. Key texts include Sangam literature, detailing early Dravidian culture."
            echo
            ;;
        7)
            echo "Exiting the guide. Thank you for exploring ancient Indian history!"
            exit 0
            ;;
        *)
            echo "Invalid choice. Please select a valid option."
            ;;
    esac
}

# Main loop to navigate through history
while true; do
    main_menu
    display_period $choice
done
